# Jalap Terminal AI Configuration
# Copy this file to .env and fill in your actual API key

# OpenAI API Key
# Get your key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (Alternative to OpenAI)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini API Key (Alternative)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Legacy support (will default to OpenAI)
JALAP_API_KEY=your-legacy-key-here

# Note: Only one API key is needed. Jalap will auto-detect the provider.
# Priority order: OpenAI > Anthropic > Google > Legacy

# Alternative: You can also set these as environment variables
# export OPENAI_API_KEY="sk-your-openai-key"
# export ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
# export GOOGLE_API_KEY="your-google-key"
